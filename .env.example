# ============================================================
# AI Trading Signal System — Environment Variables
# Copy to .env:  cp .env.example .env
# NEVER commit .env to GitHub!
# ============================================================

# App
APP_ENV=development
LOG_LEVEL=INFO

# Signal settings
MIN_CONFIDENCE=65
LOOKAHEAD_BARS=3
PROFIT_TARGET_PCT=0.0015

# Data
DEFAULT_INTERVAL=5m
DEFAULT_PERIOD=60d
AUTO_REFRESH_SECONDS=15

# Claude AI chatbot (optional)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Angel One API (optional — for live order execution)
# Get key: https://smartapi.angelbroking.com
ANGELONE_API_KEY=your_key_here
ANGELONE_CLIENT_ID=your_client_id_here
